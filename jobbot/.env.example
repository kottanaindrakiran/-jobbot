# ─────────────────────────────────────────────────────────────────────────────
#  JobBot — .env.example
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LinkedIn credentials ──────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Naukri credentials ────────────────────────────────────────────────────────
NAUKRI_EMAIL=your_naukri_email@gmail.com
NAUKRI_PASSWORD=your_naukri_password

# ── Google Service Account (Gmail + Sheets) ───────────────────────────────────
# Paste the full contents of your service account JSON as a single-line value
GMAIL_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}

GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project-id",...}

# ── Google Sheet ID ───────────────────────────────────────────────────────────
# From your sheet URL: https://docs.google.com/spreadsheets/d/<THIS_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Digest / notification email ───────────────────────────────────────────────
MY_EMAIL=your_personal_email@gmail.com
